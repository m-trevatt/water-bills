---
import Base from '../layouts/Base.astro';
import rates from '../data/rates.json';
import copySource from '../content/overview.md?raw';
import { renderCopy } from '../lib/render-copy.js';

const R24 = rates.years['2024-25'];
const R25 = rates.years['2025-26'];
const R26 = rates.years['2026-27'];
const H = rates.company_headlines_26_27;
const prev = rates.previous_year_context;

const pct = (a, b) => (((b - a) / a) * 100).toFixed(1);
const fmt = (n, d = 2) => '£' + n.toFixed(d);
const sign = (n) => (parseFloat(n) > 0 ? '+' : '') + n + '%';

const rows = [
  { label: 'Water supply, per cubic metre', a0: R24.water_supply_per_cubic_metre_gbp, a: R25.water_supply_per_cubic_metre_gbp, b: R26.water_supply_per_cubic_metre_gbp, dp: 3 },
  { label: 'Water supply, annual standing charge', a0: R24.water_supply_standing_gbp, a: R25.water_supply_standing_gbp, b: R26.water_supply_standing_gbp, dp: 2 },
  { label: 'Wastewater, per cubic metre', a0: R24.wastewater_per_cubic_metre_gbp, a: R25.wastewater_per_cubic_metre_gbp, b: R26.wastewater_per_cubic_metre_gbp, dp: 3 },
  { label: 'Wastewater, annual standing charge', a0: R24.wastewater_standing_gbp, a: R25.wastewater_standing_gbp, b: R26.wastewater_standing_gbp, dp: 2 },
  { label: 'Surface water drainage, annual', a0: R24.surface_water_drainage_gbp, a: R25.surface_water_drainage_gbp, b: R26.surface_water_drainage_gbp, dp: 2 }
];

const combinedCompoundPct = (((1 + prev.combined_average_rise_pct / 100) * (1 + H.combined_average_rise_pct / 100)) - 1) * 100;
const waterOnlyCompoundPct = (((1 + prev.combined_average_rise_pct / 100) * (1 + H.water_supply_only_rise_pct / 100)) - 1) * 100;

const baselineBill = 420;
const compoundFactor = (1 + prev.combined_average_rise_pct/100) * (1 + H.combined_average_rise_pct/100);
const currentBill = baselineBill * compoundFactor;

const vars = {
  compound_combined: combinedCompoundPct.toFixed(0),
  compound_water_only: waterOnlyCompoundPct.toFixed(0),
  prev_rise: prev.combined_average_rise_pct,
  current_rise: H.combined_average_rise_pct,
  baseline_bill: baselineBill.toFixed(0),
  current_bill: currentBill.toFixed(0),
  monthly_rise: ((currentBill - baselineBill) / 12).toFixed(0)
};

const segments = renderCopy(copySource, vars);
---

<Base title="Overview" currentPath="/" dek="How Southern Water bills rose about 58% in two years, and how we got here">
  {segments.map(seg => {
    if (seg.type === 'html') {
      return <Fragment set:html={seg.html} />;
    }
    if (seg.name === 'rates-table') {
      return (
        <table class="rates-table">
          <caption class="visually-hidden">Southern Water metered household rates, 2024-25 through 2026-27.</caption>
          <thead>
            <tr>
              <th scope="col">Charge</th>
              <th scope="col" class="num">2024-25</th>
              <th scope="col" class="num">2025-26</th>
              <th scope="col" class="num">2026-27</th>
              <th scope="col" class="num">2-yr change</th>
            </tr>
          </thead>
          <tbody>
            {rows.map(r => {
              const d = pct(r.a0, r.b);
              const up = parseFloat(d) > 0;
              return (
                <tr>
                  <td>{r.label}</td>
                  <td class="num">{fmt(r.a0, r.dp)}</td>
                  <td class="num">{fmt(r.a, r.dp)}</td>
                  <td class="num">{fmt(r.b, r.dp)}</td>
                  <td class={`num delta ${up ? '' : 'delta-down'}`}>{sign(d)}</td>
                </tr>
              );
            })}
          </tbody>
        </table>
      );
    }
    if (seg.name === 'action-panel') {
      return (
        <aside class="action-panel" aria-label="What you can do">
          <p class="action-panel-lede"><strong>Take action now.</strong></p>
          <div class="actions">
            <a class="btn primary" href="/complain">Draft a complaint to Southern Water</a>
            <a class="btn ghost" href="/write-to-mp">Write to your MP</a>
          </div>
          <p class="action-panel-note">
            If you are struggling to pay, Southern Water's social tariff gives at least a 45% discount for eligible households.<a class="cite" href="/sources#12" aria-label="Source 12">12</a>
          </p>
        </aside>
      );
    }
    if (seg.name === 'cta-buttons') {
      return (
        <div class="actions">
          <a class="btn primary" href="/complain">Draft a complaint to Southern Water</a>
          <a class="btn ghost" href="/write-to-mp">Write to your MP</a>
        </div>
      );
    }
    if (seg.name === 'closing-flag') {
      return (
        <div class="flag">
          <strong>This site is not a campaign and is not party affiliated.</strong> It was built by a local who doesn't think this is fair. It does not offer legal advice.
        </div>
      );
    }
    return null;
  })}
</Base>
