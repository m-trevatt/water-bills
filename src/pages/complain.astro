---
import Base from '../layouts/Base.astro';
---

<Base title="Complain" currentPath="/complain" dek="Draft a formal complaint to Southern Water">
  <h1 class="hed">
    The first step is a complaint letter.
    <span class="small">Ten working days is the response clock. If they miss it, or the reply does not address what you asked, you can escalate.</span>
  </h1>

  <p class="lead">
    Fill in what you have. The letter renders as you type. Nothing is sent until you send it. Nothing is stored.
  </p>

  <div class="supplier-gate" id="supplier-gate" data-module="supplier-gate">
    <div class="q">Who is your supplier? Check the top of your bill.</div>
    <div class="options" role="radiogroup" aria-label="Supplier">
      <button type="button" data-supplier="southern" aria-pressed="true">Southern Water</button>
      <button type="button" data-supplier="southeast" aria-pressed="false">South East Water</button>
      <button type="button" data-supplier="other" aria-pressed="false">Something else</button>
    </div>
    <p class="note">
      In Kent, wastewater is always Southern Water. Water supply can be Southern Water, South East Water, or another provider depending on where you live. If you are not sure, the canonical check is the <a href="https://www.water.org.uk/customers/find-your-supplier" rel="noopener noreferrer">Water UK postcode finder</a>.
    </p>
  </div>

  <div id="supplier-mismatch" class="flag" hidden>
    <strong>This complaint letter is written for Southern Water.</strong> If your supplier is different, the figures on the letter will be wrong. Use your own supplier's published charges scheme and adjust. The <a href="/write-to-mp">letter to your MP</a> is supplier-agnostic and works for you either way.
  </div>

  <form class="builder" id="complaint-form" autocomplete="on" novalidate>
    <h2>Who you are</h2>
    <label for="fullName">Full name</label>
    <input type="text" id="fullName" name="fullName" autocomplete="name" />

    <label for="address">Address</label>
    <input type="text" id="address" name="address" autocomplete="street-address" placeholder="Number, street, town" />

    <label for="postcode">Postcode</label>
    <input type="text" id="postcode" name="postcode" autocomplete="postal-code" placeholder="ME7 2ST" />

    <label for="accountNumber">Account number, if you have it</label>
    <input type="text" id="accountNumber" name="accountNumber" placeholder="Leave blank if unsure" />

    <h2>The bill</h2>
    <div class="row-2">
      <div>
        <label for="billPeriodFrom">Period from</label>
        <input type="date" id="billPeriodFrom" name="billPeriodFrom" />
      </div>
      <div>
        <label for="billPeriodTo">Period to</label>
        <input type="date" id="billPeriodTo" name="billPeriodTo" />
      </div>
    </div>

    <div class="row-2">
      <div>
        <label for="previousBill">Previous bill &pound; (optional)</label>
        <input type="number" id="previousBill" name="previousBill" step="0.01" min="0" />
      </div>
      <div>
        <label for="currentBill">Current bill &pound; (optional)</label>
        <input type="number" id="currentBill" name="currentBill" step="0.01" min="0" />
      </div>
    </div>

    <h2>What you are asking for</h2>
    <fieldset class="checks">
      <label><input type="checkbox" name="breakdown" checked /> An itemised breakdown of the bill, showing meter readings and how the period is split across the rate change</label>
      <label><input type="checkbox" name="scheme_match" checked /> Written confirmation that the rates applied match the published 2026-27 charges scheme</label>
      <label><input type="checkbox" name="meter_test" /> A meter test for accuracy</label>
      <label><input type="checkbox" name="social_tariff" /> A written statement of my social tariff and hardship fund eligibility</label>
    </fieldset>
  </form>

  <h2>The letter</h2>

  <div class="preview-wrap">
    <pre class="preview" id="preview" aria-live="polite"></pre>
  </div>

  <div class="actions">
    <button type="button" class="btn primary" id="copy-btn">Copy to clipboard</button>
    <button type="button" class="btn ghost" id="download-btn">Download as .txt</button>
    <button type="button" class="btn ghost" id="mailto-btn">Open in email app</button>
  </div>

  <p class="status" id="status" aria-live="polite"></p>

  <div class="flag" id="mailto-warn" hidden>
    Your letter is long. Some email apps, Outlook especially, will truncate the body when opened from a link. If the draft looks cut off, use <strong>Copy to clipboard</strong> and paste into a new email instead.
  </div>

  <h2>Sending</h2>
  <p>
    Email to <a href="mailto:customerservices@southernwater.co.uk">customerservices@southernwater.co.uk</a>, or post to PO Box 41, Worthing BN13 3NZ.
  </p>
  <p>
    Keep a copy. The clock is 10 working days. If there is no reply, or the reply does not cover what you asked, escalate to the <a href="https://www.ccw.org.uk" rel="noopener noreferrer">Consumer Council for Water</a>.
  </p>

  <script>
    import { generateComplaintLetter } from '../lib/letter-complaint.js';
    import { copyToClipboard, downloadAsText, openMailto, MAILTO_BODY_SAFE_LIMIT } from '../lib/delivery.js';

    const form = document.getElementById('complaint-form');
    const preview = document.getElementById('preview');
    const status = document.getElementById('status');
    const mailtoWarn = document.getElementById('mailto-warn');
    const mismatch = document.getElementById('supplier-mismatch');
    const gate = document.getElementById('supplier-gate');

    let supplier = 'southern';

    // Supplier gate
    gate.querySelectorAll('button[data-supplier]').forEach(btn => {
      btn.addEventListener('click', () => {
        gate.querySelectorAll('button[data-supplier]').forEach(b =>
          b.setAttribute('aria-pressed', b === btn ? 'true' : 'false')
        );
        supplier = btn.getAttribute('data-supplier');
        mismatch.hidden = (supplier === 'southern');
      });
    });

    function read() {
      const data = new FormData(form);
      const concerns = {};
      ['breakdown', 'scheme_match', 'meter_test', 'social_tariff'].forEach(k => {
        concerns[k] = form.querySelector(`[name="${k}"]`)?.checked ?? false;
      });
      return {
        fullName: (data.get('fullName') || '').toString(),
        address: (data.get('address') || '').toString(),
        postcode: (data.get('postcode') || '').toString(),
        accountNumber: (data.get('accountNumber') || '').toString(),
        billPeriodFrom: (data.get('billPeriodFrom') || '').toString(),
        billPeriodTo: (data.get('billPeriodTo') || '').toString(),
        previousBill: (data.get('previousBill') || '').toString(),
        currentBill: (data.get('currentBill') || '').toString(),
        concerns
      };
    }

    function render() {
      const letter = generateComplaintLetter(read());
      preview.textContent = letter;
      mailtoWarn.hidden = letter.length <= MAILTO_BODY_SAFE_LIMIT;
    }

    form.addEventListener('input', render);
    form.addEventListener('change', render);
    render();

    function setStatus(msg) {
      status.textContent = msg;
      setTimeout(() => { if (status.textContent === msg) status.textContent = ''; }, 4000);
    }

    document.getElementById('copy-btn').addEventListener('click', async () => {
      const r = await copyToClipboard(preview.textContent);
      setStatus(r.ok ? 'Copied.' : 'Copy failed. Select the letter and copy manually.');
    });

    document.getElementById('download-btn').addEventListener('click', () => {
      const stamp = new Date().toISOString().slice(0, 10);
      downloadAsText(preview.textContent, `southern-water-complaint-${stamp}.txt`);
      setStatus('Downloaded.');
    });

    document.getElementById('mailto-btn').addEventListener('click', () => {
      openMailto({
        to: 'customerservices@southernwater.co.uk',
        subject: 'Formal complaint, stage 1, household account',
        body: preview.textContent
      });
    });
  </script>
</Base>
