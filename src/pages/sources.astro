---
import Base from '../layouts/Base.astro';
import citations from '../data/citations.json';
import copySource from '../content/sources.md?raw';
import { renderCopy } from '../lib/render-copy.js';

const items = Object.entries(citations)
  .filter(([k]) => k !== '_meta')
  .map(([key, c]) => ({ key, ...c }))
  .sort((a, b) => a.id - b.id);

const vars = {
  audit_date: citations._meta.last_audit,
  audit_note: citations._meta.audit_note
};

const segments = renderCopy(copySource, vars);
---

<Base title="Sources" currentPath="/sources" dek="Every claim, traced">
  {segments.map(seg => {
    if (seg.type === 'html') {
      return <Fragment set:html={seg.html} />;
    }
    if (seg.name === 'sources-list') {
      return (
        <ol class="sources-list">
          {items.map(c => (
            <li id={String(c.id)}>
              <div class="num-col">{c.id}</div>
              <div>
                <div class="title">{c.title}</div>
                <div class="pub">{c.publisher}</div>
                <a class="url" href={c.url} rel="noopener noreferrer">{c.url}</a>
                <div class="supports">{c.supports}</div>
                <div class="accessed">Accessed {c.accessed} &middot; {c.type}</div>
              </div>
            </li>
          ))}
        </ol>
      );
    }
    return null;
  })}
</Base>
